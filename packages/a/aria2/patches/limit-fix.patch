From 3f2d6eecedf24b134d81d24d90af6f825a22b3c7 Mon Sep 17 00:00:00 2001
From: myfreeer <myfreeer@users.noreply.github.com>
Date: Tue, 5 Jun 2018 16:49:07 +0800
Subject: [PATCH] Update default options for aria2

Adjust `--max-connection-per-server` to allow up to 1024 connections,
and change the default `--piece-length` to 1K.
---
 src/OptionHandlerFactory.cc | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/OptionHandlerFactory.cc b/src/OptionHandlerFactory.cc
index e69b2f7..a34b8c3 100644
--- a/src/OptionHandlerFactory.cc
+++ b/src/OptionHandlerFactory.cc
@@ -905,7 +905,7 @@ std::vector<OptionHandler*> OptionHandlerFactory::createOptionHandlers() {
     OptionHandler* op(new UnitNumberOptionHandler(
         PREF_PIECE_LENGTH, TEXT_PIECE_LENGTH, "1M", 1_m, 1_g));
     op->addTag(TAG_ADVANCED);
-    op->addTag(TAG_HTTP);
+    op->addTag(TAG_HTTP);
     op->setInitialOption(true);
     op->setChangeGlobalOption(true);
     handlers.push_back(op);
@@ -439,7 +439,7 @@ std::vector<OptionHandler*> OptionHandlerFactory::createOptionHandlers() {
     OptionHandler* op(new NumberOptionHandler(
         PREF_MAX_CONNECTION_PER_SERVER,
         TEXT_MAX_CONNECTION_PER_SERVER,
-        "1", 1, 16, 'x'));
+        "1", 1, 1024, 'x'));
     op->addTag(TAG_BASIC);
     op->addTag(TAG_FTP);
     handlers.push_back(op);
